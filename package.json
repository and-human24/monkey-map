{
  "name": "monkey-map",
  "version": "1.0.0",
  "description": "FigJam-like mind map tool - click to open desktop app",
  "license": "MIT",
  "type": "module",
  "bin": {
    "monkey-map": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build:web": "cd web && pnpm build",
    "build:cli": "tsup",
    "build": "pnpm build:web && pnpm build:cli",
    "build:app": "cd web && pnpm tauri build",
    "postbuild:cli": "chmod +x dist/cli.js",
    "test": "vitest run",
    "test:all": "vitest run && cd web && pnpm test"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "open": "^10.1.2",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/ws": "^8.18.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
